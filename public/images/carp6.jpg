		<style type="text/css" id="wp-custom-css">
			@media only screen and (min-width: 1240px) {
    #Top_bar.is-sticky {
			height: 90px!important;
	}
	.menuo-right #Top_bar.is-sticky .menu_wrapper {
		float:left!important;
		margin-left:25%!important;
	}
	.header-stack.header-center #Top_bar:not(.is-sticky) .menu_wrapper {
    width: 100%;
		margin-left:0px!important;
}
	    #Top_bar.is-sticky #logo img.logo-sticky {
        display: inline;
        max-height: 90px!important;
				padding-left: 50%;
				padding-top:5%;
}
}

#mega-menu-wrap-main-menu #mega-menu-main-menu > li.mega-menu-flyout ul.mega-sub-menu {
	width:max-content!important;
}



.fancybox-thumbs__list a:before {
    border: 3px solid #afafaf !important;

}

.widget_mfn_menu ul li a {
    display: block;
    padding: 7px 10px;
    margin-bottom: 5px;
    background: #fff;
    border: 1px solid rgba(0, 0, 0, .04);
    color: #000000;
}




.scroll_nautica {
	overflow-y:scroll;
	max-height:150px;
}

.scroll_sidebar .sub-menu, .scroll_mobile .sub-menu {
		overflow-y:scroll!important;
	max-height:150px!important;
}

.scroll_sidebar .sub-menu a{
		background:#f4f4f4!important;
	color:#000!important;
}

.scroll_sidebar .widget_mfn_menu ul li.current-menu-item:not(.current-menu-ancestor) > a, .widget_mfn_menu ul li.current_page_item:not(.current_page_ancestor) > a{
		/*color:#00AEFD!important;*/
	background-color:#00AEFD!important;
	color:#fff!important;
}



.scroll_sidebar .sub-menu a:hover{
	color:#000!important;
}

.scroll_sidebar .sub-menu a:active, .scroll_sidebar ul li.current-menu-item a {
	background-color:#00AEFD!important;
	color:#fff!important;
}

::-webkit-scrollbar {
    width: 4px;
}

::-webkit-scrollbar-thumb {
    background-color: rgba(0, 0, 0, 0.5);
    border-radius: 10px;
}

::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.2);
}




/* Nasconde badge recaptcha */

.grecaptcha-badge{ 
    visibility: hidden !important; 
    opacity:0 !important; 
} 



		</style>
		
