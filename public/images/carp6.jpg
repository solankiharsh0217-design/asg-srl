<link rel="https://api.w.org/" href="https://www.asg-srl.it/wp-json/" /><link rel="EditURI" type="application/rsd+xml" title="RSD" href="https://www.asg-srl.it/xmlrpc.php?rsd" />
<meta name="generator" content="WordPress 6.6.5" />
        <style>
            /* Stili per la topbar */
            .custom-phone-topbar {
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                z-index: 999999;
                background-color: #333333;
                color: white;
                padding: 10px 20px;
                text-align: center;
                font-size: 14px;
                box-shadow: 0 2px 5px rgba(0,0,0,0.1);
                transition: all 0.3s ease;
                height: 45px;
                box-sizing: border-box;
            }
            
            /* Altezza topbar mobile */
            @media (max-width: 768px) {
                .custom-phone-topbar {
                    height: 60px !important;
                    padding: 15px 20px;
                }
            }
            
            .custom-phone-topbar a {
                color: white;
                text-decoration: none;
                font-weight: 500;
            }
            
            .custom-phone-topbar a:hover {
                text-decoration: underline;
            }
            
            /* Icona telefono personalizzabile */
            .phone-icon {
                color: #ffffff;
                display: inline-block;
                width: 16px;
                height: 16px;
                margin-right: 5px;
                vertical-align: middle;
            }
            
            .phone-icon svg {
                width: 100%;
                height: 100%;
                fill: currentColor;
            }
            
            /* Stili per desktop */
            .phone-desktop {
                display: inline-block;
            }
            
            .phone-mobile {
                display: none;
            }
            
            .phone-mobile-btn {
                background-color: #007cba;
                color: #ffffff;
                padding: 8px 16px;
                border-radius: 5px;
                text-decoration: none;
                font-weight: bold;
                display: inline-block;
                transition: background-color 0.3s ease;
            }
            
            .phone-mobile-btn:hover {
                background-color: #006394;
                color: #ffffff;
                text-decoration: none;
            }
            
            /* Media query per mobile */
            @media (max-width: 768px) {
                .phone-desktop {
                    display: none;
                }
                
                .phone-mobile {
                    display: inline-block;
                }
            }
            
            /* Compensazione per il body */
            html {
                margin-top: 45px !important;
            }
            
            /* Mobile compensation */
            @media (max-width: 768px) {
                html {
                    margin-top: 60px !important;
                }
            }
            
            body {
                margin-top: 0 !important;
            }
            
            /* Fix specifico per Header placeholder DESKTOP */
            .header_placeholder {
                height: 45px !important;
            }
            
            /* Fix specifico per Header placeholder MOBILE */
            @media (max-width: 768px) {
                .header_placeholder {
                    height: 45px !important;
                }
                
                /* Header deve iniziare subito dopo la topbar */
                #Top_bar {
                    margin-top: 0 !important;
                    padding-top: 0 !important;
                }
            }
            
            /* Fix specifico per Top bar quando diventa sticky */
            #Top_bar.is-sticky {
                top: 5px !important;
            }
            
            /* Mobile sticky adjustment */
            @media (max-width: 768px) {
                #Top_bar.is-sticky {
                    top: 10px !important;
                }
            }
            
            /* Fix per Header wrapper */
            #Header_wrapper {
                margin-top: 0 !important;
                padding-top: 0 !important;
            }
            
            /* Fix per admin bar se presente - SOLO SE VISIBILE */
            html.admin-bar {
                margin-top: 122px !important;
            }
            
            body.admin-bar #Top_bar.is-sticky {
                top: 82px !important;
            }
            
            /* NON modificare placeholder per admin bar - gestito da JS */
            
            @media screen and (max-width: 782px) {
                html.admin-bar {
                    margin-top: 136px !important;
                }
                
                body.admin-bar #Top_bar.is-sticky {
                    top: 96px !important;
                }
            }
            
            /* Admin bar + mobile fix - SOLO margin e sticky */
            @media screen and (max-width: 768px) {
                html.admin-bar {
                    margin-top: 137px !important;
                }
                
                body.admin-bar #Top_bar.is-sticky {
                    top: 87px !important;
                }
            }
            
            @media screen and (max-width: 768px) and (max-width: 782px) {
                html.admin-bar {
                    margin-top: 151px !important;
                }
                
                body.admin-bar #Top_bar.is-sticky {
                    top: 101px !important;
                }
            }
            
            /* Fix aggiuntivi per temi */
            #Header {
                position: relative !important;
            }
            
            /* Fix per Revolution Slider */
            .mfn-main-slider {
                margin-top: 0 !important;
            }
            
            /* Fix per contenuti */
            #Content {
                margin-top: 0 !important;
                padding-top: 0 !important;
            }
            
            /* Mobile: elimina qualsiasi spazio extra */
            @media (max-width: 768px) {
                #Header, #Header_wrapper, #Top_bar {
                    margin: 0 !important;
                    padding-top: 0 !important;
                }
            }
            
            /* Fix per sticky header in modalità responsive */
            @media (max-width: 1239px) {
                #Top_bar.is-sticky {
                    top: 5px !important;
                }
                
                body.admin-bar #Top_bar.is-sticky {
                    top: 82px !important;
                }
            }
            
            @media screen and (max-width: 782px) {
                body.admin-bar #Top_bar.is-sticky {
                    top: 96px !important;
                }
            }
        </style>
        
        <div class="custom-phone-topbar">
            <!-- Versione Desktop -->
            <span class="phone-desktop">
                <span class="phone-icon">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
