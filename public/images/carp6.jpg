        <script>
        // JavaScript dinamico con valori personalizzabili
        document.addEventListener('DOMContentLoaded', function() {
            // Valori personalizzabili dal plugin
            const settings = {
                heightDesktop: 45,
                heightMobile: 60,
                placeholderHeightDesktop: 45,
                placeholderHeightMobile: 45,
                placeholderHeightDesktopSticky: 160,
                placeholderHeightMobileSticky: 45,
                stickyOffsetDesktop: -40,
                stickyOffsetMobile: -50            };
            
            // Funzione per aggiustare gli header
            function adjustHeader() {
                const topbar = document.querySelector('#Top_bar');
                const headerPlaceholder = document.querySelector('.header_placeholder');
                const customTopbar = document.querySelector('.custom-phone-topbar');
                
                if (!topbar || !customTopbar) return;
                
                const isMobile = window.innerWidth <= 768;
                const topbarHeight = isMobile ? settings.heightMobile : settings.heightDesktop;
                const stickyOffset = isMobile ? settings.stickyOffsetMobile : settings.stickyOffsetDesktop;
                
                // Verifica se admin bar è realmente visibile (non solo se la classe esiste)
                const adminBar = document.querySelector('#wpadminbar');
                const isAdminBarVisible = adminBar && window.getComputedStyle(adminBar).display !== 'none';
                const adminBarHeight = isAdminBarVisible ? 
                    (window.innerWidth <= 782 ? 46 : 32) : 0;
                
                const totalStickyOffset = topbarHeight + stickyOffset + adminBarHeight;
                
                // Determina quale placeholder height usare - SENZA aggiungere admin bar
                let placeholderHeight;
                if (topbar.classList.contains('is-sticky')) {
                    placeholderHeight = isMobile ? settings.placeholderHeightMobileSticky : settings.placeholderHeightDesktopSticky;
                } else {
                    placeholderHeight = isMobile ? settings.placeholderHeightMobile : settings.placeholderHeightDesktop;
                }
                
                // NON aggiungere admin bar al placeholder - usa il valore esatto dalle impostazioni
                const totalPlaceholderHeight = placeholderHeight;
                
                // Aggiusta la posizione del Top_bar quando è sticky
                if (topbar.classList.contains('is-sticky')) {
                    topbar.style.top = totalStickyOffset + 'px';
                    topbar.style.setProperty('top', totalStickyOffset + 'px', 'important');
                } else {
                    topbar.style.removeProperty('top');
                }
                
                // Aggiusta l'altezza del placeholder - USA VALORE ESATTO
                if (headerPlaceholder) {
                    headerPlaceholder.style.height = totalPlaceholderHeight + 'px';
                    headerPlaceholder.style.setProperty('height', totalPlaceholderHeight + 'px', 'important');
                }
            }
            
            // Esegui al caricamento
            adjustHeader();
            
            // Esegui al ridimensionamento
            window.addEventListener('resize', adjustHeader);
            
            // Osserva i cambiamenti nella classe is-sticky del Top_bar
            const topbar = document.querySelector('#Top_bar');
            if (topbar) {
                const observer = new MutationObserver(function(mutations) {
                    mutations.forEach(function(mutation) {
                        if (mutation.type === 'attributes' && 
                            (mutation.attributeName === 'class' || mutation.attributeName === 'style')) {
                            setTimeout(adjustHeader, 10);
                        }
                    });
                });
                
                observer.observe(topbar, {
                    attributes: true,
                    attributeFilter: ['class', 'style']
                });
            }
            
            // Forza l'aggiustamento con delay progressivi
            setTimeout(adjustHeader, 100);
            setTimeout(adjustHeader, 500);
            setTimeout(adjustHeader, 1000);
        });
        </script>
